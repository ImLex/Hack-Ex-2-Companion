{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // Expo's base config sets customConditions: ["react-native"], which stops
    // TypeScript resolving "bun:test". Naming bun here loads its types directly.
    "types": ["bun"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules"]
}
